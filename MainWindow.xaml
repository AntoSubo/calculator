<Window x:Class="calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="350" Width="300">
    <Window.Resources>
        <Style x:Key="CalculatorButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0C0C0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#A0A0A0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Name="Display"
                   Grid.Row="0"
                   FontSize="24"
                   TextAlignment="Right" 
                   Margin="0 0 0 5"
                   Padding="5"
                   Background="#F5F5F5"
                   Text="0"/>

        <UniformGrid Grid.Row="1" Rows="4" Columns="4">
            <Button Content="7" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
            <Button Content="8" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
            <Button Content="9" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
            <Button Content="/" Style="{StaticResource CalculatorButtonStyle}" Click="Operation_Click"/>

            <Button Content="4" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
            <Button Content="5" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
            <Button Content="6" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
            <Button Content="*" Style="{StaticResource CalculatorButtonStyle}" Click="Operation_Click"/>

            <Button Content="1" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
            <Button Content="2" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
            <Button Content="3" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
            <Button Content="-" Style="{StaticResource CalculatorButtonStyle}" Click="Operation_Click"/>

            <Button Content="0" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
            <Button Content="C" Style="{StaticResource CalculatorButtonStyle}" Click="Clear_Click"/>
            <Button Content="=" Style="{StaticResource CalculatorButtonStyle}" Click="Equals_Click"/>
            <Button Content="+" Style="{StaticResource CalculatorButtonStyle}" Click="Operation_Click"/>
        </UniformGrid>
    </Grid>
</Window>